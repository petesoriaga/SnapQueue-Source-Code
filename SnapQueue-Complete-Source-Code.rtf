  async function resolveRefund() \{\line
    if (!selectedPaymentId) return;\line
    if (refundForm.action === "reject" && String(refundForm.refundAdminNote || "").trim().length < 8) \{\line
      setRefundModalError("Admin note is required when rejecting a refund and must be at least 8 characters.");\line
      ignoreFeedback("Admin note is required when rejecting a refund and must be at least 8 characters.", "error");\line
      return;\line
    \}\line
    if (refundForm.action === "process") \{\line
      if (!/^\\d\{12\}$/.test(String(refundForm.refundReferenceNumber || "").trim())) \{\line
        setRefundModalError("Refund reference number must be exactly 12 digits.");\line
        ignoreFeedback("Refund reference number must be exactly 12 digits.", "error");\line
        return;\line
      \}\line
      if (!String(refundForm.refundProofUrl || "").trim()) \{\line
        setRefundModalError("Upload the refund proof image before processing the refund.");\line
        ignoreFeedback("Upload the refund proof image before processing the refund.", "error");\line
        return;\line
      \}\line
    \}\line
    try \{\line
      setRefundModalError("");\line
      setRefundSubmitting(true);\line
      setRefundDebugInfo(`Sending refund request...\\nPayment ID: $\{selectedPaymentId\}\\nAction: $\{String(refundForm.action || "").toUpperCase()\}`);\line
      const response = await api.post(`/payments/$\{encodeURIComponent(selectedPaymentId)\}/refund/resolve`, refundForm, \{ timeout: 60000 \});\line
      setRefundDebugInfo(\line
        `Success\\nHTTP: $\{response?.status || 200\}\\nPayment ID: $\{selectedPaymentId\}\\nAction: $\{String(refundForm.action || "").toUpperCase()\}\\nMessage: $\{response?.data?.message || "Refund action submitted."\}`\line
      );\line
      const updatedPayment = response?.data?.payment || null;\line
      if (updatedPayment?._id) \{\line
        const updatedReservationId =\line
          typeof updatedPayment?.reservationId === "object"\line
            ? String(updatedPayment?.reservationId?._id || updatedPayment?.reservationId?.id || "")\line
            : String(updatedPayment?.reservationId || "");\line
        setPayments((current) =>\line
          current.map((item) => (String(item?._id || "") === String(updatedPayment._id || "") ? \{ ...item, ...updatedPayment \} : item))\line
        );\line
        if (updatedReservationId.trim()) \{\line
          setReservations((current) =>\line
            current.map((item) =>\line
              String(item?._id || item?.id || "") === updatedReservationId\line
                ? \{\line
                    ...item,\line
                    paymentStatus: String(updatedPayment.status || "").toLowerCase() === "refunded" ? "refunded" : item.paymentStatus\line
                  \}\line
                : item\line
            )\line
          );\line
        \}\line
      \}\line
      setRefundModalOpen(false);\line
      setRefundSubmitting(false);\line
      ignoreFeedback("Refund action submitted.");\line
      Promise.allSettled([loadPayments(), loadReservations()]);\line
    \} catch (error) \{\line
      setRefundSubmitting(false);\line
      const message = errorMessage(error, "Failed to resolve refund.");\line
      setRefundModalError(message);\line
      setRefundDebugInfo(\line
        `Failed\\nHTTP: $\{error?.response?.status || "NO_RESPONSE"\}\\nPayment ID: $\{selectedPaymentId\}\\nAction: $\{String(refundForm.action || "").toUpperCase()\}\\nCode: $\{error?.code || "-"\}\\nMessage: $\{message\}`\line
      );\line
      ignoreFeedback(message, "error");\line
    \}\line
  \}\line
