  async function handleSaveEmailNotifications(enabled) \{\line
    setProfileDraft((current) => (\{ ...current, emailNotificationsEnabled: enabled \}));\line
    try \{\line
      const response = await api.patch("/users/me", \{ emailNotificationsEnabled: enabled \});\line
      const persisted = response?.data?.user?.emailNotificationsEnabled !== false;\line
      setProfileDraft((current) => (\{ ...current, emailNotificationsEnabled: persisted \}));\line
      setUser((current) => current ? \{ ...current, emailNotificationsEnabled: persisted \} : current);\line
      if (user) \{\line
        window.localStorage.setItem("bcp_profile", JSON.stringify(\{\line
          fullName: user.fullName || "",\line
          email: user.email || "",\line
          phone: user.phone || "",\line
          bio: user.bio || "",\line
          avatarUrl: user.avatarUrl || "",\line
          googleAvatarUrl: user.googleAvatarUrl || "",\line
          createdAt: user.createdAt || "",\line
          emailNotificationsEnabled: persisted\line
        \}));\line
      \}\line
      ignoreFeedback(\{ variant: "success", message: `Email notifications $\{persisted ? "enabled" : "disabled"\}.` \});\line
    \} catch (error) \{\line
      setProfileDraft((current) => (\{ ...current, emailNotificationsEnabled: !enabled \}));\line
      ignoreFeedback(\{ variant: "error", message: error?.response?.data?.message || "Failed to save email settings." \});\line
    \}\line
  \}\line
