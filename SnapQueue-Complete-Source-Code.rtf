    refundAction,\line
    refundAdminNote,\line
    refundReferenceNumber,\line
    refundProofUrl\line
  \} = req.body;\line
  const validStatuses = ["pending", "approved", "rejected", "completed"];\line
  const validStages = ["awaiting_approval", "approved", "shoot_completed", "editing", "ready_for_download"];\line
  const isAdmin = hasAdminAccess(req.user?.role);\line
\line
  if (!status && !workflowStage && !estimatedDelivery) \{\line
    return res.status(400).json(\{ success: false, message: "Status, workflowStage, or estimatedDelivery is required" \});\line
  \}\line
