\line
const finalizeAiReply = (answer, question, articles = []) => \{\line
  const trimmed = String(answer || "").trim();\line
  if (!trimmed) return "";\line
\line
  const lines = trimmed\line
    .split("\\n")\line
    .map((line) => line.trimEnd())\line
    .filter((line, index, arr) => line || (index > 0 && arr[index - 1]));\line
