  const helpfulIndex = lines.findIndex((line) => /^Helpful links:\\s*$/i.test(String(line || "").trim()));\line
  if (helpfulIndex === -1) \{\line
    return \{ body: source, links: [] \};\line
  \}\line
\line
  const body = lines.slice(0, helpfulIndex).join("\\n").trim();\line
  const links = [];\line
  for (let index = helpfulIndex + 1; index < lines.length; index += 1) \{\line
    const match = String(lines[index] || "").trim().match(/^-\\s*(.+?):\\s*(https?:\\/\\/\\S+|\\/\\S+)$/i);\line
    if (!match) continue;\line
    links.push(\{\line
      label: cleanHelpfulLinkLabel(match[1], match[2]),\line
      href: match[2].trim()\line
    \});\line
  \}\line
\line
  return \{ body, links \};\line
\};\line
\line
const mergeHelpfulLinks = (text, additionalLinksBlock) => \{\line
  const \{ body, links \} = splitHelpfulLinksBlock(text);\line
  const extra = splitHelpfulLinksBlock(additionalLinksBlock).links;\line
  const merged = [];\line
  const seen = new Set();\line
