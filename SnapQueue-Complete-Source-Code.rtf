  const parts = new Intl.DateTimeFormat("en-US", \{\line
    timeZone: MANILA_TIMEZONE,\line
    year: "numeric",\line
    month: "2-digit",\line
    day: "2-digit"\line
  \}).formatToParts(date);\line
  const year = parts.find((part) => part.type === "year")?.value || "";\line
  const month = parts.find((part) => part.type === "month")?.value || "";\line
  const day = parts.find((part) => part.type === "day")?.value || "";\line
  return year && month && day ? `$\{year\}-$\{month\}-$\{day\}` : "";\line
\};\line
