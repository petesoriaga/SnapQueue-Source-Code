export const sendLiveThreadMessage = async (req, res) => \{\line
  if (!mongoose.Types.ObjectId.isValid(req.params.threadId)) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid threadId" \});\line
  \}\line
\line
  const text = String(req.body?.text || "").trim();\line
  if (!text) \{\line
    return res.status(400).json(\{ success: false, message: "Message text is required" \});\line
  \}\line
  if (text.length > MAX_MESSAGE_LENGTH) \{\line
    return res.status(400).json(\{ success: false, message: `Message must be $\{MAX_MESSAGE_LENGTH\} characters or less` \});\line
  \}\line
\line
  const thread = await LiveChatThread.findById(req.params.threadId);\line
  if (!thread) \{\line
    return res.status(404).json(\{ success: false, message: "Thread not found" \});\line
  \}\line
  if (!canAccessThread(thread, req.user)) \{\line
    return res.status(403).json(\{ success: false, message: "Forbidden" \});\line
  \}\line
\line
  if (thread.status === "closed") \{\line
    if (hasAdminAccess(req.user?.role)) \{\line
      thread.status = "open";\line
    \} else \{\line
      return res.status(409).json(\{ success: false, message: "This chat is closed by admin" \});\line
    \}\line
  \}\line
\line
  const profile = await User.findById(req.user.sub).select("fullName email").lean();\line
  const senderRole = hasAdminAccess(req.user?.role) ? "admin" : "user";\line
  const senderName = profile?.fullName || profile?.email || req.user?.email || senderRole;\line
\line
  const message = await LiveChatMessage.create(\{\line
    threadId: thread._id,\line
    senderId: req.user.sub,\line
    senderRole,\line
    senderName,\line
    text\line
  \});\line
\line
  thread.lastMessage = text;\line
  thread.lastMessageAt = message.createdAt;\line
  if (senderRole === "admin") \{\line
    thread.unreadForClient = Number(thread.unreadForClient || 0) + 1;\line
    thread.unreadForAdmin = 0;\line
  \} else \{\line
    thread.unreadForAdmin = Number(thread.unreadForAdmin || 0) + 1;\line
    thread.unreadForClient = 0;\line
  \}\line
  await thread.save();\line
\line
  notifyLiveChatMessage(thread, message).catch((error) => \{\line
    console.error("Live chat email notification failed", \{\line
      threadId: String(thread?._id || ""),\line
      messageId: String(message?._id || ""),\line
      message: error?.message\line
    \});\line
  \});\line
\line
  res.status(201).json(\{ success: true, message: message \});\line
\};\line
