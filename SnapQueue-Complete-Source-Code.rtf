  if (proofFingerprint) filters.push(\{ proofFingerprint \});\line
  if (Number.isFinite(amount) && amount > 0) filters.push(\{ amount \});\line
  if (!filters.length) \{\line
    return \{ autoReviewStatus: "needs_review", findings: ["Payment submission is incomplete and requires manual review."] \};\line
  \}\line
\line
  const relatedPayments = await Payment.find(\{\line
    ...(paymentId ? \{ _id: \{ $ne: paymentId \} \} : \{\}),\line
    $or: filters\line
  \})\line
    .select("reservationId referenceNumber proofFingerprint amount status")\line
    .lean();\line
\line
  const activePayments = relatedPayments.filter((item) => ACTIVE_PAYMENT_STATUSES.includes(String(item?.status || "").toLowerCase()));\line
  if (referenceNumber && activePayments.some((item) => String(item?.referenceNumber || "") === referenceNumber)) \{\line
    findings.push("Duplicate reference number detected on another payment.");\line
  \}\line
  if (proofFingerprint && activePayments.some((item) => String(item?.proofFingerprint || "") === proofFingerprint)) \{\line
