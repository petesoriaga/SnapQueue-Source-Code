export const cancelReservationByUser = async (req, res) => \{\line
  const normalizedCancellationReason = String(req.body?.cancellationReason || "").trim();\line
  if (normalizedCancellationReason.length < 8 || normalizedCancellationReason.length > 500) \{\line
    return res.status(400).json(\{ success: false, message: "Cancellation reason must be 8-500 characters." \});\line
  \}\line
\line
  const reservation = await findReservationByIdentifier(req.params.id);\line
  if (!reservation) \{\line
    return res.status(404).json(\{ success: false, message: "Reservation not found" \});\line
  \}\line
\line
  if (!isReservationOwner(reservation, req.user)) \{\line
    return res.status(403).json(\{ success: false, message: "Forbidden" \});\line
  \}\line
\line
  const currentStatus = String(reservation.status || "").toLowerCase();\line
  if (["rejected", "completed"].includes(currentStatus)) \{\line
    return res.status(409).json(\{ success: false, message: "Reservation cannot be cancelled in its current status" \});\line
  \}\line
\line
  const payment = await Payment.findOne(\{ reservationId: reservation._id \});\line
  let refundRequested = false;\line
  if (payment?.status === "verified") \{\line
    const currentRefundStatus = String(payment.refundStatus || "none");\line
    if (currentRefundStatus === "rejected") \{\line
      return res.status(409).json(\{ success: false, message: "Refund for this payment was already rejected. Please contact admin support." \});\line
    \}\line
    if (currentRefundStatus === "none") \{\line
      payment.refundStatus = "requested";\line
      payment.refundReason = `User cancelled reservation: $\{normalizedCancellationReason\}`;\line
      payment.refundRequestedAt = new Date();\line
      payment.refundRequestedBy = req.user?.sub || null;\line
      payment.refundResolvedAt = null;\line
      payment.refundResolvedBy = null;\line
      await payment.save();\line
      refundRequested = true;\line
    \}\line
  \}\line
\line
  reservation.status = "rejected";\line
  reservation.userCancellationReason = normalizedCancellationReason;\line
  reservation.cancelledByRole = "user";\line
  reservation.cancelledAt = new Date();\line
\line
  if (!payment || ["pending", "processing", "needs_review"].includes(String(payment.status || "").toLowerCase())) \{\line
    const cancelResult = await Payment.updateMany(\line
      \{ reservationId: reservation._id, status: \{ $in: ["pending", "processing", "needs_review"] \} \},\line
      \{\line
        $set: \{\line
          status: "cancelled",\line
          failureReason: "Reservation was cancelled by user.",\line
          failedAt: new Date()\line
        \}\line
      \}\line
    );\line
    if (cancelResult.modifiedCount > 0) \{\line
      reservation.paymentStatus = "cancelled";\line
    \}\line
  \} else if (String(payment.status || "").toLowerCase() === "verified") \{\line
    reservation.paymentStatus = "paid";\line
  \} else if (String(payment.status || "").toLowerCase() === "refunded") \{\line
    reservation.paymentStatus = "refunded";\line
  \}\line
\line
  await reservation.save();\line
  return res.json(\{ success: true, reservation, refundRequested \});\line
\};\line
