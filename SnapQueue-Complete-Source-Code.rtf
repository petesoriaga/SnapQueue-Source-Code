  async function reloadDashboardData() \{\line
    const reservationResponse = await api.get("/reservations/dashboard").catch(() => api.get("/reservations"));\line
    const archiveResponse = await api.get("/archive/me").catch(() => (\{ data: \{ folders: [] \} \}));\line
    const nextReservations = reservationResponse?.data?.reservations || reservationResponse?.data?.items || [];\line
    const nextFolders = archiveResponse?.data?.folders || archiveResponse?.data?.items || [];\line
    setReservations(nextReservations);\line
    setArchiveFolders(nextFolders);\line
    if (user) \{\line
      const storedNotifications = loadStoredNotifications(user);\line
      const storedReadIds = loadReadUserNotifications(user);\line
      const storedDismissedIds = loadDismissedUserNotifications(user);\line
      const syncedNotifications = syncNotificationsFromReservations(storedNotifications, nextReservations, \{\line
        readIds: storedReadIds,\line
        dismissedIds: storedDismissedIds\line
      \});\line
      const nextReadIds = Array.from(new Set([\line
        ...storedReadIds,\line
        ...getNotificationFlagIds(syncedNotifications, "read")\line
      ]));\line
      const nextDismissedIds = Array.from(new Set([\line
        ...storedDismissedIds,\line
        ...getNotificationFlagIds(syncedNotifications, "dismissed")\line
      ]));\line
      setUserNotifications(syncedNotifications);\line
      setReadNotificationIds(nextReadIds);\line
      setDismissedNotificationIds(nextDismissedIds);\line
      saveReadUserNotifications(user, nextReadIds);\line
      saveDismissedUserNotifications(user, nextDismissedIds);\line
      saveStoredNotifications(user, syncedNotifications);\line
    \}\line
  \}\line
\line
  useEffect(() => \{\line
    if (!user) return undefined;\line
\line
    const refreshDashboard = () => \{\line
      if (document.visibilityState === "visible") \{\line
        reloadDashboardData().catch(() => \{\});\line
      \}\line
    \};\line
\line
    const intervalId = window.setInterval(refreshDashboard, 15000);\line
    window.addEventListener("focus", refreshDashboard);\line
    document.addEventListener("visibilitychange", refreshDashboard);\line
\line
    return () => \{\line
      window.clearInterval(intervalId);\line
      window.removeEventListener("focus", refreshDashboard);\line
      document.removeEventListener("visibilitychange", refreshDashboard);\line
    \};\line
  \}, [user]);\line
