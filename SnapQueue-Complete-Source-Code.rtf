  async function savePassword() \{\line
    setPasswordOtpState((current) => (\{ ...current, error: "" \}));\line
    const passwordContext = \{\line
      fullName: me?.fullName || profileForm.fullName || "",\line
      email: me?.email || profileForm.email || ""\line
    \};\line
    const requiresCurrentPassword = !adminRequiresPasswordSetup;\line
    const nextErrors = \{\line
      currentPassword: requiresCurrentPassword ? (passwordForm.currentPassword ? "" : "Current password is required.") : "",\line
      newPassword: passwordForm.newPassword\line
        ? !isStrongPassword(passwordForm.newPassword, passwordContext)\line
          ? "Use at least 8 characters with lowercase, number, special character, and no spaces."\line
          : requiresCurrentPassword && passwordForm.currentPassword && String(passwordForm.newPassword) === String(passwordForm.currentPassword)\line
            ? "New password must be different from current password."\line
            : ""\line
        : "New password is required.",\line
      confirmPassword: passwordForm.confirmPassword\line
        ? (String(passwordForm.newPassword) === String(passwordForm.confirmPassword) ? "" : "New password and confirmation do not match.")\line
        : "Please confirm your new password."\line
    \};\line
    setPasswordErrors(nextErrors);\line
    const firstErrorField = nextErrors.currentPassword ? "currentPassword" : nextErrors.newPassword ? "newPassword" : nextErrors.confirmPassword ? "confirmPassword" : "";\line
    if (firstErrorField) \{\line
      setPasswordShakeField(firstErrorField);\line
      window.setTimeout(() => setPasswordShakeField((current) => (current === firstErrorField ? "" : current)), 420);\line
    \}\line
    if ((requiresCurrentPassword && !passwordForm.currentPassword) || !passwordForm.newPassword || !passwordForm.confirmPassword) \{\line
      ignoreFeedback(requiresCurrentPassword ? "All password fields are required." : "New password and confirmation are required.", "error");\line
      return;\line
    \}\line
    if (requiresCurrentPassword) \{\line
      try \{\line
        await api.post("/users/me/password/verify-current", \{ currentPassword: passwordForm.currentPassword \}, \{ timeout: 30000 \});\line
      \} catch (error) \{\line
        const message = errorMessage(error, "Current password is incorrect.");\line
        setPasswordErrors((current) => (\{ ...current, currentPassword: message \}));\line
        setPasswordShakeField("currentPassword");\line
        window.setTimeout(() => setPasswordShakeField((current) => (current === "currentPassword" ? "" : current)), 420);\line
        ignoreFeedback(message, "error");\line
        return;\line
      \}\line
    \}\line
    if (!isStrongPassword(passwordForm.newPassword, passwordContext)) \{\line
      setPasswordShakeField("newPassword");\line
      window.setTimeout(() => setPasswordShakeField((current) => (current === "newPassword" ? "" : current)), 420);\line
      ignoreFeedback("Use at least 8 characters with lowercase, number, special character, and no spaces.", "error");\line
      return;\line
    \}\line
    if (requiresCurrentPassword && String(passwordForm.newPassword) === String(passwordForm.currentPassword)) \{\line
      setPasswordErrors((current) => (\{ ...current, newPassword: "New password must be different from current password." \}));\line
      setPasswordShakeField("newPassword");\line
      window.setTimeout(() => setPasswordShakeField((current) => (current === "newPassword" ? "" : current)), 420);\line
      ignoreFeedback("New password must be different from current password.", "error");\line
      return;\line
    \}\line
    if (String(passwordForm.newPassword) !== String(passwordForm.confirmPassword)) \{\line
      setPasswordShakeField("confirmPassword");\line
      window.setTimeout(() => setPasswordShakeField((current) => (current === "confirmPassword" ? "" : current)), 420);\line
      ignoreFeedback("New password and confirmation do not match.", "error");\line
      return;\line
    \}\line
    setPasswordSaving(true);\line
    try \{\line
      const response = await api.post("/users/me/password/request-otp", passwordForm, \{ timeout: 30000 \});\line
      setPasswordOtpState(\{\line
        step: "otp",\line
        challengeId: String(response?.data?.challengeId || ""),\line
        code: "",\line
        delivery: String(response?.data?.delivery || ""),\line
        email: String(response?.data?.email || ""),\line
        expiresInSeconds: Number(response?.data?.expiresInSeconds || 0),\line
        devCode: String(response?.data?.devCode || ""),\line
        error: "",\line
        sending: false,\line
        verifying: false\line
      \});\line
      ignoreFeedback(String(response?.data?.message || "Verification code sent."));\line
    \} catch (error) \{\line
      const message = errorMessage(error, "Failed to update password.");\line
      if (error?.response?.status === 401) \{\line
        setPasswordErrors((current) => (\{ ...current, currentPassword: "Current password is incorrect." \}));\line
        setPasswordShakeField("currentPassword");\line
        window.setTimeout(() => setPasswordShakeField((current) => (current === "currentPassword" ? "" : current)), 420);\line
      \}\line
      setPasswordOtpState((current) => (\{ ...current, error: message \}));\line
      ignoreFeedback(message, "error");\line
    \} finally \{\line
      setPasswordSaving(false);\line
    \}\line
  \}\line
