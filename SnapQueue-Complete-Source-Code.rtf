export const getOrCreateLiveThreadForAdmin = async (req, res) => \{\line
  const userId = String(req.body?.userId || "").trim();\line
  if (!mongoose.Types.ObjectId.isValid(userId)) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid userId" \});\line
  \}\line
\line
  const profile = await User.findById(userId).select("fullName email role").lean();\line
  if (!profile) \{\line
    return res.status(404).json(\{ success: false, message: "User not found" \});\line
  \}\line
  if (hasAdminAccess(profile.role)) \{\line
    return res.status(409).json(\{ success: false, message: "Live chat can only be started for client accounts." \});\line
  \}\line
\line
  let thread = await LiveChatThread.findOne(\{ clientId: userId \}).sort(\{ updatedAt: -1 \});\line
  if (!thread) \{\line
    thread = await LiveChatThread.create(\{\line
      clientId: userId,\line
      clientName: profile?.fullName || "Client",\line
      clientEmail: profile?.email || ""\line
    \});\line
  \} else \{\line
    const nextName = profile?.fullName || thread.clientName || "Client";\line
    const nextEmail = profile?.email || thread.clientEmail || "";\line
    let changed = false;\line
    if (thread.clientName !== nextName) \{\line
      thread.clientName = nextName;\line
      changed = true;\line
    \}\line
    if (thread.clientEmail !== nextEmail) \{\line
      thread.clientEmail = nextEmail;\line
      changed = true;\line
    \}\line
    if (thread.status === "closed") \{\line
      thread.status = "open";\line
      changed = true;\line
    \}\line
    if (changed) \{\line
      await thread.save();\line
    \}\line
  \}\line
\line
  res.status(200).json(\{ success: true, thread \});\line
\};\line
