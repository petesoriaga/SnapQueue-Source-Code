    if (status === "cancelled") await applyStatusToReservation(payment.reservationId, "cancelled");\line
    else if (["processing", "pending", "needs_review"].includes(status)) await applyStatusToReservation(payment.reservationId, "processing");\line
    else if (status === "refunded") await applyStatusToReservation(payment.reservationId, "refunded");\line
