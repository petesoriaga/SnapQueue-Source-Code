        );\line
        return;\line
      \}\line
      printHtmlDocument(\line
        receiptHtml,\line
        () => ignoreFeedback(\{ variant: "error", message: "Unable to print receipt." \})\line
      );\line
    \} catch (_error) \{\line
      ignoreFeedback(\{ variant: "error", message: isMobileReceiptViewport() ? "Unable to download receipt." : "Unable to print receipt." \});\line
    \}\line
