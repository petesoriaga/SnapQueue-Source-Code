                  <p className="mx-auto text-[11px] leading-5 text-slate-300">\{tab === "signin" ? <>By proceeding, you agree to our <Link to="/terms" className="font-bold text-sky-300 hover:text-sky-200">Terms</Link> and <Link to="/privacy-policy" className="font-bold text-sky-300 hover:text-sky-200">Privacy Policy</Link>.</> : tab === "verify-2fa" ? `Enter the code sent to $\{twoFactor.email || "your email address"\} to $\{twoFactor.mode === "signup" ? "finish creating your account" : "finish signing in"\}.` : setupPasswordMode ? "Your Google account is connected. Create a password here before continuing to your dashboard." : "Access and manage your account securely."\}</p>\line
