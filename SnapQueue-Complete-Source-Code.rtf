  if (["rejected", "completed"].includes(reservationStatus)) \{\line
    const err = new Error("Payment is not allowed for this reservation status.");\line
    err.code = 409;\line
    throw err;\line
  \}\line
  const expectedAmount = resolveExpectedAmount(reservation);\line
