            <Icon className="h-4 w-4" path=\{<><path strokeLinecap="round" strokeLinejoin="round" d="M12 8v4" /><path strokeLinecap="round" strokeLinejoin="round" d="M12 16h.01" /><path strokeLinecap="round" strokeLinejoin="round" d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /></>\} />\line
