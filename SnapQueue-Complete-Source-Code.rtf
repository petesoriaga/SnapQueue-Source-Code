  if (Number(thread?.[unreadField] || 0) > 0) \{\line
    thread[unreadField] = 0;\line
    await thread.save();\line
  \}\line
\line
  const messages = await LiveChatMessage.find(filter).sort(\{ createdAt: 1 \}).limit(300);\line
  res.json(\{ success: true, thread: serializeThread(thread, req.user), messages \});\line
\};\line
