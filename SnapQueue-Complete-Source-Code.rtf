export const notFound = (_req, res) => \{\line
  res.status(404).json(\{ success: false, message: "Route not found" \});\line
\};\line
\line
export const errorHandler = (error, _req, res, _next) => \{\line
  const status = error.statusCode || error.status || 500;\line
  if (status >= 500) \{\line
    console.error("Unhandled server error", \{\line
      message: error?.message,\line
      stack: error?.stack\line
    \});\line
  \}\line
  if (error?.type === "entity.too.large") \{\line
    return res.status(413).json(\{\line
      success: false,\line
      message: "Upload payload is too large for the current server path."\line
    \});\line
  \}\line
  if (String(error?.code || "").startsWith("LIMIT_")) \{\line
    return res.status(413).json(\{\line
      success: false,\line
      message: error.message || "Upload exceeded server multipart limits."\line
    \});\line
  \}\line
  res.status(status).json(\{\line
    success: false,\line
    message: error.message || "Internal server error"\line
  \});\line
\};\line
