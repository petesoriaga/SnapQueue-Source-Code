    const label = String(item?.label || "").trim();\line
    const href = String(item?.href || "").trim();\line
    if (!label || !href) continue;\line
    const key = `$\{label\}|$\{href\}`;\line
    if (seen.has(key)) continue;\line
    seen.add(key);\line
