\line
  if (!nextLabel && KNOWN_LINKS[hrefText]) return KNOWN_LINKS[hrefText];\line
  if (/media archive/i.test(nextLabel)) return "Media Archive";\line
  if (/booking history/i.test(nextLabel)) return "Booking History";\line
  if (/project status/i.test(nextLabel)) return "Project Status";\line
  if (/help center/i.test(nextLabel)) return "Help Center";\line
