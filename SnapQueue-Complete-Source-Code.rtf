import Advertisement from "../../shared/models/Advertisement.js";\line
\line
const parseDate = (value) => \{\line
  if (value === undefined || value === null || value === "") return null;\line
  const parsed = new Date(value);\line
  if (Number.isNaN(parsed.getTime())) return null;\line
  return parsed;\line
\};\line
\line
const toDayStart = (value) => \{\line
  if (!value) return null;\line
  const date = new Date(value);\line
  if (Number.isNaN(date.getTime())) return null;\line
  date.setHours(0, 0, 0, 0);\line
  return date;\line
\};\line
\line
const toDayEnd = (value) => \{\line
  if (!value) return null;\line
  const date = new Date(value);\line
  if (Number.isNaN(date.getTime())) return null;\line
  date.setHours(23, 59, 59, 999);\line
  return date;\line
\};\line
\line
const normalizePayload = (body = \{\}) => \{\line
  const payload = \{\};\line
  if (typeof body.title === "string") payload.title = body.title.trim();\line
  if (typeof body.description === "string") payload.description = body.description.trim();\line
  if (typeof body.imageUrl === "string") payload.imageUrl = body.imageUrl.trim();\line
  if (typeof body.linkUrl === "string") payload.linkUrl = body.linkUrl.trim();\line
  if (typeof body.isActive === "boolean") payload.isActive = body.isActive;\line
  if (Object.prototype.hasOwnProperty.call(body, "startDate")) payload.startDate = parseDate(body.startDate);\line
  if (Object.prototype.hasOwnProperty.call(body, "endDate")) payload.endDate = parseDate(body.endDate);\line
  return payload;\line
\};\line
\line
const assertDateRange = (startDate, endDate) => \{\line
  if (startDate && endDate && startDate.getTime() > endDate.getTime()) \{\line
    return "Start date cannot be later than end date";\line
  \}\line
  return "";\line
\};\line
\line
const rangesOverlap = (startA, endA, startB, endB) => \{\line
  if (!startA || !endA || !startB || !endB) return false;\line
  return startA.getTime() <= endB.getTime() && startB.getTime() <= endA.getTime();\line
\};\line
\line
const assertScheduleAvailability = async (startDate, endDate, excludeId = "") => \{\line
  if (!startDate || !endDate) return "";\line
  const query = \{\line
    startDate: \{ $ne: null \},\line
    endDate: \{ $ne: null \}\line
  \};\line
  if (excludeId && mongoose.Types.ObjectId.isValid(excludeId)) \{\line
    query._id = \{ $ne: excludeId \};\line
  \}\line
  const existingAds = await Advertisement.find(query).select("title startDate endDate");\line
  const conflictingAd = existingAds.find((item) => rangesOverlap(startDate, endDate, item.startDate, item.endDate));\line
  if (!conflictingAd) return "";\line
  return `Selected dates overlap with "$\{conflictingAd.title || "another advertisement"\}"`;\line
\};\line
\line
export const listActiveAds = async (_req, res) => \{\line
  const now = new Date();\line
  const candidates = await Advertisement.find(\{ isActive: true \}).sort(\{ createdAt: -1 \});\line
  const ads = candidates.filter((ad) => \{\line
    const start = toDayStart(ad.startDate);\line
    const end = toDayEnd(ad.endDate);\line
    if (start && now < start) return false;\line
    if (end && now > end) return false;\line
    return true;\line
  \});\line
  res.json(\{ success: true, ads \});\line
\};\line
\line
export const listAdsAdmin = async (_req, res) => \{\line
