      const response = await api.post("/auth/signin", \{\line
        email: normalizedEmail,\line
        password: normalizedPassword\line
      \});\line
      if (response?.data?.requiresTwoFactor) \{\line
        setTwoFactor(\{\line
          ...buildTwoFactorState(\{ ...response?.data, mode: "signin" \}, normalizedEmail)\line
        \});\line
        setTab("verify-2fa");\line
        ignoreFeedback(\{\line
          message: verificationDeliveryMessage(response?.data, normalizedEmail),\line
          variant: "success"\line
        \});\line
        return;\line
      \}\line
      const user = response?.data?.user || \{\};\line
      await finalizeLogin(user, response?.data?.token, "Sign in successful!");\line
    \} catch (error) \{\line
      setErrors((current) => (\{\line
        ...current,\line
        signinPassword: error?.response?.status === 401 ? "Wrong password. Please try again." : "Unable to sign in with these credentials."\line
      \}));\line
      setTouched((current) => (\{ ...current, signinPassword: true \}));\line
      setShakeField("signinPassword");\line
      ignoreFeedback(\{ message: error?.response?.data?.message || "Sign in failed!", variant: "error" \});\line
    \} finally \{\line
      setLoading((current) => (\{ ...current, signin: false \}));\line
    \}\line
  \}\line
\line
  async function handleVerifyTwoFactor(event) \{\line
    event.preventDefault();\line
    const code = String(twoFactor.code || "").trim();\line
    if (!/^\\d\{6\}$/.test(code)) \{\line
      ignoreFeedback(\{ message: "Enter the 6-digit verification code.", variant: "error" \});\line
      return;\line
    \}\line
    setLoading((current) => (\{ ...current, signin: true \}));\line
    try \{\line
      const endpoint = twoFactor.mode === "signup" ? "/auth/signup/verify" : "/auth/signin/verify-2fa";\line
      const response = await api.post(endpoint, \{\line
        challengeId: twoFactor.challengeId,\line
        code\line
      \});\line
      const user = response?.data?.user || \{\};\line
      await finalizeLogin(\line
        user,\line
        response?.data?.token,\line
        twoFactor.mode === "signup" ? "Account created successfully!" : "Two-factor verification successful!"\line
      );\line
    \} catch (error) \{\line
      ignoreFeedback(\{ message: error?.response?.data?.message || "Verification failed.", variant: "error" \});\line
    \} finally \{\line
      setLoading((current) => (\{ ...current, signin: false \}));\line
    \}\line
  \}\line
\line
  async function handleResendTwoFactor() \{\line
    if (!twoFactor.challengeId) return;\line
    setLoading((current) => (\{ ...current, signin: true \}));\line
    try \{\line
      const endpoint = twoFactor.mode === "signup" ? "/auth/signup/resend-otp" : "/auth/signin/resend-2fa";\line
      const response = await api.post(endpoint, \{ challengeId: twoFactor.challengeId \});\line
      setTwoFactor((current) => (\{\line
        ...current,\line
        mode: twoFactor.mode,\line
        challengeId: String(response?.data?.challengeId || current.challengeId),\line
        delivery: String(response?.data?.delivery || current.delivery),\line
        email: String(response?.data?.email || current.email),\line
        devCode: String(response?.data?.devCode || ""),\line
        resendCooldown: 30,\line
        expiresInSeconds: Number(response?.data?.expiresInSeconds || current.expiresInSeconds || 0)\line
      \}));\line
      ignoreFeedback(\{\line
        message: response?.data?.emailDelayed\line
          ? `Verification code is still being delivered to $\{String(response?.data?.email || twoFactor.email || "your email")\}. Please wait a bit, then try again if needed.`\line
          : verificationDeliveryMessage(response?.data, twoFactor.email),\line
        variant: "success"\line
      \});\line
    \} catch (error) \{\line
      ignoreFeedback(\{ message: error?.response?.data?.message || "Could not resend verification code.", variant: "error" \});\line
    \} finally \{\line
      setLoading((current) => (\{ ...current, signin: false \}));\line
    \}\line
  \}\line
\line
  async function handleSignUp(event) \{\line
    event.preventDefault();\line
    const nextErrors = \{\line
      signupName: signUp.fullName.trim().length > 1 ? "" : "Full name is required.",\line
      signupEmail: validateEmail(signUp.email) ? "" : "Email format is invalid.",\line
      signupPassword: isStrongPassword(signUp.password) ? "" : "Password does not meet all requirements.",\line
      signupConfirm: signUp.password === signUp.confirm && signUp.confirm ? "" : "Passwords do not match."\line
    \};\line
    setTouched((current) => (\{\line
      ...current,\line
      signupName: true,\line
      signupEmail: true,\line
      signupPassword: true,\line
      signupConfirm: true\line
    \}));\line
    setErrors((current) => (\{ ...current, ...nextErrors \}));\line
    if (Object.values(nextErrors).some(Boolean)) \{\line
      ignoreFeedback(\{ message: "Please complete the signup requirements.", variant: "error" \});\line
      return;\line
    \}\line
    setLoading((current) => (\{ ...current, signup: true \}));\line
    try \{\line
      const response = await api.post("/auth/signup", \{\line
        fullName: signUp.fullName.trim(),\line
        email: signUp.email.toLowerCase(),\line
        password: signUp.password\line
      \});\line
      if (response?.data?.requiresVerification) \{\line
        setTwoFactor(buildTwoFactorState(\{ ...response?.data, mode: "signup" \}, signUp.email.toLowerCase().trim()));\line
        setTab("verify-2fa");\line
        ignoreFeedback(\{\line
          message: verificationDeliveryMessage(response?.data, signUp.email.toLowerCase().trim()),\line
          variant: "success"\line
        \});\line
        return;\line
      \}\line
      ignoreFeedback(\{ message: "Signup succeeded but verification was not started.", variant: "error" \});\line
    \} catch (error) \{\line
      ignoreFeedback(\{ message: error?.response?.data?.message || "Sign up failed!", variant: "error" \});\line
    \} finally \{\line
      setLoading((current) => (\{ ...current, signup: false \}));\line
    \}\line
  \}\line
\line
  async function handleForgotSubmit(event) \{\line
    event.preventDefault();\line
    const nextErrors = !(resetToken || setupPasswordMode)\line
      ? \{ forgotEmail: validateEmail(forgot.email) ? "" : "Email format is invalid." \}\line
      : \{\line
          forgotNewPassword: isStrongPassword(forgot.newPassword) ? "" : "Password does not meet all requirements.",\line
          forgotConfirmPassword: forgot.confirmPassword === forgot.newPassword ? "" : "Passwords do not match."\line
        \};\line
    setTouched((current) => (\{\line
      ...current,\line
      forgotEmail: true,\line
      forgotNewPassword: true,\line
      forgotConfirmPassword: true\line
    \}));\line
    setErrors((current) => (\{ ...current, ...nextErrors \}));\line
    if (Object.values(nextErrors).some(Boolean)) return;\line
\line
    setLoading((current) => (\{ ...current, forgot: true \}));\line
    try \{\line
      if (setupPasswordMode) \{\line
        await api.post("/users/me/password", \{\line
          newPassword: forgot.newPassword,\line
          confirmPassword: forgot.confirmPassword\line
        \});\line
        window.localStorage.removeItem(GOOGLE_PASSWORD_SETUP_STORAGE_KEY);\line
        let resolvedUser = null;\line
        try \{\line
          const meResponse = await api.get("/auth/me");\line
          if (meResponse?.data?.user) \{\line
            resolvedUser = meResponse.data.user;\line
            window.localStorage.setItem("bcp_profile", JSON.stringify(buildProfileCache(resolvedUser)));\line
          \}\line
        \} catch (_error) \{\line
          resolvedUser = null;\line
        \}\line
        ignoreFeedback(\{ message: "Password set successfully. Redirecting...", variant: "success" \});\line
        window.setTimeout(() => \{\line
          window.location.replace(resolvePostLoginTarget(resolvedUser, redirectTarget, reservationTarget));\line
        \}, 700);\line
      \} else if (!resetToken) \{\line
        await api.post("/auth/forgot-password", \{ email: forgot.email.toLowerCase().trim() \});\line
        ignoreFeedback(\{ message: "If the email exists, a reset link has been sent.", variant: "success" \});\line
      \} else \{\line
        await api.post("/auth/reset-password", \{ token: resetToken, password: forgot.newPassword \});\line
        setResetToken("");\line
        setTab("signin");\line
        navigate("/login", \{ replace: true \});\line
      \}\line
    \} catch (error) \{\line
      ignoreFeedback(\{ message: error?.response?.data?.message || "Reset failed.", variant: "error" \});\line
    \} finally \{\line
      setLoading((current) => (\{ ...current, forgot: false \}));\line
    \}\line
  \}\line
\line
  return (\line
    <div className="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-900">\line
