  async function handleSendUserMessage() \{\line
    const text = String(messageComposerText || "").trim();\line
    if (!text || messageSending) return;\line
\line
    if (String(selectedMessageThread?.threadType || "") === "ai") \{\line
      const userMessage = \{\line
        _id: `ai-user-$\{Date.now()\}`,\line
        createdAt: new Date().toISOString(),\line
        senderRole: "user",\line
        senderName: user?.fullName || "You",\line
        text\line
      \};\line
      setMessageComposerText("");\line
      setMessageSending(true);\line
      setAiMessages((current) => [...current, userMessage]);\line
      try \{\line
        const response = await api.post("/chatbot/ai", \{ question: text \});\line
        const answerText = String(response?.data?.answer || "I couldn't generate a reply right now.").trim();\line
        const answerProvider = String(response?.data?.provider || "").trim().toLowerCase();\line
        setAiMessages((current) => [\line
          ...current,\line
          \{\line
            _id: `ai-assistant-$\{Date.now()\}`,\line
            createdAt: new Date().toISOString(),\line
            senderRole: "assistant",\line
            senderName: "AI Assistant",\line
            text: answerText,\line
            provider: answerProvider\line
          \}\line
        ]);\line
      \} catch (error) \{\line
        ignoreFeedback(\{ variant: "error", message: error?.response?.data?.message || error?.message || "Failed to contact AI assistant." \});\line
      \} finally \{\line
        setMessageSending(false);\line
      \}\line
      return;\line
    \}\line
\line
    setMessageSending(true);\line
    try \{\line
      const threadId = await ensureAdminSupportThread();\line
      if (!threadId) throw new Error("Admin support thread is unavailable.");\line
      setSelectedMessageThreadId(threadId);\line
      setMessageComposerText("");\line
      await api.post(`/chatbot/live/threads/$\{encodeURIComponent(threadId)\}/messages`, \{ text \});\line
      await Promise.allSettled([\line
        loadAdminSupportMessages(threadId, \{ silent: true \}),\line
        loadMessageThreads(\{ silent: true \})\line
      ]);\line
    \} catch (error) \{\line
      ignoreFeedback(\{ variant: "error", message: error?.response?.data?.message || error?.message || "Failed to send message." \});\line
    \} finally \{\line
      setMessageSending(false);\line
    \}\line
  \}\line
