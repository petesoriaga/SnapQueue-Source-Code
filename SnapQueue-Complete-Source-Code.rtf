const MIN_PASSWORD_LENGTH = 8;\line
\line
const normalizeComparable = (value) => String(value || "").toLowerCase().replace(/[^a-z0-9]/g, "");\line
\line
const getPersonalFragments = (\{ fullName, email \} = \{\}) => \{\line
  const fragments = new Set();\line
  const add = (value) => \{\line
    const normalized = normalizeComparable(value);\line
    if (normalized.length >= 3) fragments.add(normalized);\line
  \};\line
\line
  const normalizedName = String(fullName || "").trim();\line
  if (normalizedName) \{\line
    normalizedName\line
      .split(/\\s+/)\line
      .map((part) => normalizeComparable(part))\line
      .filter((part) => part.length >= 3)\line
      .forEach((part) => fragments.add(part));\line
    add(normalizedName);\line
  \}\line
\line
  const normalizedEmail = String(email || "").trim().toLowerCase();\line
  if (normalizedEmail) \{\line
    const [localPart = ""] = normalizedEmail.split("@");\line
    localPart\line
      .split(/[._%+-]+/)\line
      .map((part) => normalizeComparable(part))\line
      .filter((part) => part.length >= 3)\line
      .forEach((part) => fragments.add(part));\line
    add(localPart);\line
  \}\line
\line
  return Array.from(fragments);\line
\};\line
\line
export const getPasswordPolicyChecks = (password, context = \{\}) => \{\line
  const value = String(password || "");\line
  const comparable = normalizeComparable(value);\line
  const personalFragments = getPersonalFragments(context);\line
\line
  return [\line
    \{\line
      key: "length",\line
      label: `At least $\{MIN_PASSWORD_LENGTH\} characters`,\line
      valid: value.length >= MIN_PASSWORD_LENGTH\line
    \},\line
    \{\line
      key: "lowercase",\line
      label: "At least one lowercase letter",\line
      valid: /[a-z]/.test(value)\line
    \},\line
    \{\line
      key: "number",\line
      label: "At least one number",\line
      valid: /\\d/.test(value)\line
    \},\line
    \{\line
      key: "special",\line
      label: "At least one special character",\line
      valid: /[^A-Za-z\\d]/.test(value)\line
    \},\line
    \{\line
      key: "spaces",\line
      label: "No spaces",\line
      valid: !/\\s/.test(value)\line
    \}\line
  ];\line
\};\line
\line
export const validatePasswordPolicy = (password, context = \{\}) => \{\line
  const failedChecks = getPasswordPolicyChecks(password, context).filter((item) => !item.valid);\line
  if (failedChecks.length === 0) return [];\line
\line
  const errors = [];\line
  if (failedChecks.some((item) => item.key === "length")) \{\line
    errors.push(`Password must be at least $\{MIN_PASSWORD_LENGTH\} characters long.`);\line
  \}\line
  if (failedChecks.some((item) => ["lowercase", "number", "special"].includes(item.key))) \{\line
    errors.push("Password must include lowercase letter, number, and special character.");\line
  \}\line
  if (failedChecks.some((item) => item.key === "spaces")) \{\line
    errors.push("Password must not contain spaces.");\line
  \}\line
  return errors;\line
\};\line
