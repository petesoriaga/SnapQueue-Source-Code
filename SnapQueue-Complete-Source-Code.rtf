import path from "node:path";\line
import \{ fileURLToPath \} from "node:url";\line
import dotenv from "dotenv";\line
import mongoose from "mongoose";\line
import Reservation from "../shared/models/Reservation.js";\line
import \{ generateReservationCode \} from "../shared/utils/reservationCode.js";\line
import \{ connectDB \} from "../core/config/db.js";\line
\line
const __filename = fileURLToPath(import.meta.url);\line
const __dirname = path.dirname(__filename);\line
const envPath = path.resolve(__dirname, "../../.env");\line
\line
if (!process.env.MONGO_URI) \{\line
  dotenv.config(\{ path: envPath \});\line
\}\line
\line
const createUniqueReservationCode = async () => \{\line
  for (let attempt = 0; attempt < 12; attempt += 1) \{\line
    const reservationCode = generateReservationCode();\line
    const existing = await Reservation.exists(\{ reservationCode \});\line
    if (!existing) return reservationCode;\line
  \}\line
  throw new Error("Unable to generate unique reservation code");\line
\};\line
\line
const backfillCodes = async () => \{\line
  await connectDB();\line
  const missing = await Reservation.find(\{\line
    $or: [\{ reservationCode: \{ $exists: false \} \}, \{ reservationCode: "" \}, \{ reservationCode: null \}]\line
  \}).select("_id").lean();\line
\line
  if (!missing.length) \{\line
    console.log("No reservations missing reservationCode.");\line
    return;\line
  \}\line
\line
  console.log(`Backfilling $\{missing.length\} reservation(s)...`);\line
  const ops = [];\line
  for (const item of missing) \{\line
    const reservationCode = await createUniqueReservationCode();\line
    ops.push(\{\line
      updateOne: \{\line
        filter: \{ _id: item._id, $or: [\{ reservationCode: \{ $exists: false \} \}, \{ reservationCode: "" \}, \{ reservationCode: null \}] \},\line
        update: \{ $set: \{ reservationCode \} \}\line
      \}\line
    \});\line
  \}\line
  if (ops.length) \{\line
    const result = await Reservation.bulkWrite(ops, \{ ordered: false \});\line
    console.log("Backfill complete.", \{\line
      matched: result.matchedCount,\line
      modified: result.modifiedCount\line
    \});\line
  \}\line
\};\line
\line
backfillCodes()\line
  .then(() => mongoose.disconnect())\line
  .catch((error) => \{\line
    console.error("Backfill failed", \{ message: error?.message \});\line
    mongoose.disconnect().finally(() => process.exit(1));\line
  \});\line
