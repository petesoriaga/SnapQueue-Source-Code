      `Section: $\{article.section\}`,\line
      `Category: $\{article.category\}`,\line
      `Steps: $\{(article.steps || []).join(" | ")\}`,\line
      `Tip: $\{article.tip || ""\}`,\line
      `Link: $\{articlePath(article)\}`\line
    ].join("\\n"))\line
    .join("\\n\\n");\line
  const appContext = [\line
    "Business: SnapQueue / BCP photo-video booking system.",\line
    "Packages: Basic PHP 2,700, Standard PHP 3,500, Premium PHP 4,500, plus custom package.",\line
    "Reservation flow: submit reservation -> admin review/approve -> payment -> production -> done.",\line
    "Navigation links: Reservation = /reservation, Payments = /dashboard?tab=payments, Project Status = /dashboard?tab=progress, Media Archive = /dashboard?tab=photos, Booking History = /dashboard?tab=history, Chat Admin = /dashboard?tab=messages, Settings = /dashboard?tab=settings, Profile = /dashboard?tab=profile, Help Center = /help-center.",\line
    "Payment: manual proof upload with reference number; refund request is available in payment records.",\line
    "Custom package flow: custom reservations may need admin quote review before payment can continue.",\line
    "Payment review: rejected payment proofs usually need a clearer screenshot or correct reference number before resubmission.",\line
    "Refund flow: some refunds require the client to submit payout details before admin can process them.",\line
    "Project tracking: clients can follow approval, production, editing, and ready-for-download stages from the dashboard.",\line
    "Media delivery: finished files appear in the Media Archive after admin uploads them.",\line
    "Profile management: users can update account details, phone number, password, and notification settings in profile settings.",\line
    "Authentication: signup may require OTP email verification, and password reset is available from the login flow.",\line
    "Support: Chat Admin is for signed-in users who need help with bookings, payments, or account concerns.",\line
    "Admin tools: admins can review booking requests, verify payments, manage refunds, update workflow stages, send newsletters, and manage advertisements.",\line
    "Guest users can use AI chat; live admin chat requires sign-in.",\line
    "User help center path: /help-center?article=<title>",\line
    "Admin help center path: /admin-help-center?article=<title>"\line
  ].join("\\n");\line
\line
  const apiKey = process.env.GEMINI_API_KEY || "";\line
  if (!apiKey) \{\line
    return res.json(\{\line
      success: true,\line
      answer: fallbackAiReply(question, qaItems),\line
      provider: "fallback",\line
      reason: "Gemini API key is not configured"\line
    \});\line
  \}\line
\line
  const configuredModel = String(process.env.GEMINI_MODEL || "").trim();\line
  const modelsToTry = configuredModel ? [configuredModel, ...DEFAULT_AI_MODELS.filter((model) => model !== configuredModel)] : DEFAULT_AI_MODELS;\line
  const instructionPrompt = [\line
    "You are the website assistant for SnapQueue.",\line
    "Answer in a natural, friendly way using short sentence-form replies.",\line
    "Keep most answers to 2 or 3 short paragraphs or fewer.",\line
    "Do not sound robotic, scripted, or overly formal.",\line
    "If the user says hello or asks generally what you can help with, reply briefly like a helpful admin, not with a long welcome script.",\line
    "Do not answer as a single short fragment unless the user asks for a very short reply.",\line
    "Use only the provided website context, FAQ context, and help center context.",\line
    "When the user asks how, where, steps, process, guide, or what to do, organize the reply with a short summary, up to 3 numbered steps, and only 1 or 2 helpful links if needed.",\line
    "When the user asks where something is, how to find a page, or what to do next in the website, include a final Helpful links section with the most relevant relative path.",\line
    "When you include links, put them only in a final Helpful links section using short labels and relative paths.",\line
    "Do not output HTML, raw anchor tags, or long absolute URLs in the middle of sentences.",\line
    "If there is a best matching article, mention its title naturally in the answer.",\line
    "If unsure, say what the user can do in the website to confirm.",\line
    "Do not invent policies, prices, article titles, or URLs."\line
  ].join(" ");\line
\line
  const requestBody = \{\line
    contents: [\line
      \{\line
        role: "user",\line
        parts: [\line
          \{\line
            text: `$\{instructionPrompt\}\\n\\nWebsite context:\\n$\{appContext\}\\n\\nFAQ context:\\n$\{faqContext\}\\n\\nHelp center context:\\n$\{helpCenterContext\}\\n\\nUser question:\\n$\{question\}`\line
          \}\line
        ]\line
