export const updateReservationPricing = async (req, res) => \{\line
  const \{ basePrice, customAdjustments, discount = 0, currency = "PHP" \} = req.body;\line
\line
  const normalizedBasePrice = parseNumberField(basePrice);\line
  const normalizedDiscount = parseNumberField(discount);\line
  if (normalizedBasePrice === null || normalizedBasePrice < 0) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid basePrice" \});\line
  \}\line
  if (normalizedDiscount === null || normalizedDiscount < 0) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid discount" \});\line
  \}\line
\line
  const normalizedCurrency = String(currency || "PHP").trim().toUpperCase();\line
  if (!normalizedCurrency) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid currency" \});\line
  \}\line
\line
  const adjustments = normalizeAdjustments(customAdjustments);\line
  const invalidAdjustment = adjustments.find((item) => !item.label || item.amount === null);\line
  if (invalidAdjustment) \{\line
    return res.status(400).json(\{ success: false, message: "Each custom adjustment requires a label and numeric amount" \});\line
  \}\line
\line
  const finalPrice = normalizedBasePrice + sumAmounts(adjustments) - normalizedDiscount;\line
  if (finalPrice <= 0) \{\line
    return res.status(400).json(\{ success: false, message: "Final price must be greater than 0" \});\line
  \}\line
\line
  const reservation = await findReservationByIdentifier(req.params.id);\line
  if (!reservation) \{\line
    return res.status(404).json(\{ success: false, message: "Reservation not found" \});\line
  \}\line
  if (!isCustomReservation(reservation)) \{\line
    return res.status(409).json(\{\line
      success: false,\line
      message: "Quotes can only be updated for custom package reservations."\line
    \});\line
  \}\line
\line
  const verifiedPayment = await Payment.exists(\{ reservationId: reservation._id, status: "verified" \});\line
  if (verifiedPayment) \{\line
    return res.status(409).json(\{ success: false, message: "Cannot update pricing after payment is verified" \});\line
  \}\line
\line
  await Payment.updateMany(\line
    \{\line
      reservationId: reservation._id,\line
      status: \{ $in: ["pending", "processing"] \}\line
    \},\line
    \{\line
      $set: \{\line
        status: "cancelled",\line
        failedAt: new Date(),\line
        failureReason: "Payment was cancelled because the reservation quote was updated."\line
      \}\line
    \}\line
  );\line
\line
  reservation.basePrice = normalizedBasePrice;\line
  reservation.customAdjustments = adjustments;\line
  reservation.discount = normalizedDiscount;\line
  reservation.finalPrice = finalPrice;\line
  reservation.currency = normalizedCurrency;\line
  reservation.pricingStatus = "quoted";\line
  reservation.quotedAt = new Date();\line
  reservation.quotedBy = req.user?.sub || null;\line
  reservation.pricingAcceptedAt = null;\line
  reservation.quoteVersion = Number(reservation.quoteVersion || 0) + 1;\line
  reservation.paymentStatus = "unpaid";\line
  reservation.pricingHistory.push(\{\line
    basePrice: normalizedBasePrice,\line
    customAdjustments: adjustments,\line
    discount: normalizedDiscount,\line
    finalPrice,\line
    currency: normalizedCurrency,\line
    quotedBy: req.user?.sub || null,\line
    quotedAt: reservation.quotedAt\line
  \});\line
\line
  await reservation.save();\line
\line
  notifyCustomQuoteProvided(reservation).catch((error) => \{\line
    console.error("Custom quote email notification failed", \{\line
      reservationId: String(reservation?._id || ""),\line
      message: error?.message\line
    \});\line
  \});\line
\line
  notifyReservationEditable(reservation).catch((error) => \{\line
    console.error("Reservation editable email notification failed", \{\line
      reservationId: String(reservation?._id || ""),\line
      message: error?.message\line
    \});\line
  \});\line
\line
  res.json(\{ success: true, reservation \});\line
\};\line
