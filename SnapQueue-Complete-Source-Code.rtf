import fs from "node:fs";\line
import path from "node:path";\line
\line
const rootDir = process.cwd();\line
const sourceDir = path.join(rootDir, "frontend", "dist");\line
const targetDir = path.join(rootDir, "backend", "client-dist");\line
\line
if (!fs.existsSync(sourceDir)) \{\line
  throw new Error(`Frontend build output not found at $\{sourceDir\}`);\line
\}\line
\line
fs.rmSync(targetDir, \{ recursive: true, force: true \});\line
fs.mkdirSync(path.dirname(targetDir), \{ recursive: true \});\line
fs.cpSync(sourceDir, targetDir, \{ recursive: true \});\line
\line
console.log(`Copied frontend build from $\{sourceDir\} to $\{targetDir\}`);\line
\par
\par
