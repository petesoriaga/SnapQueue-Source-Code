import \{ useEffect, useMemo, useRef, useState \} from "react";\line
import \{ useLocation \} from "react-router-dom";\line
import api from "../../../shared/services/api";\line
\line
const MODE_COPY = \{\line
  maintenance: \{\line
    label: "Maintenance Mode",\line
    title: "We'll Be Back Soon",\line
    message: "SnapQueue is temporarily unavailable for scheduled maintenance. The website cannot be accessed by users right now. Please try again later."\line
  \},\line
  vacation: \{\line
