    const steps = Array.isArray(primary?.steps) ? primary.steps.filter(Boolean).slice(0, 3) : [];\line
    if (steps.length) \{\line
      nextAnswer = [\line
        ensureSentenceEnding(nextAnswer),\line
        "",\line
        "Steps:",\line
        ...steps.map((step, index) => `$\{index + 1\}. $\{ensureSentenceEnding(step)\}`)\line
      ].join("\\n");\line
    \}\line
  \} else \{\line
    nextAnswer = ensureSentenceEnding(nextAnswer);\line
  \}\line
\line
  if (!hasLinks && !hasHelpfulLinksLabel && articles.length) \{\line
    const linksBlock = formatHelpLinks(articles.slice(0, wantsSteps ? 2 : 1));\line
