        lastError = error;\line
        modelErrors.push(\{ model, apiBase, reason: error?.message || "Unknown Gemini error" \});\line
      \}\line
    \}\line
  \}\line
\line
  const diagnosticReason = modelErrors.length\line
    ? modelErrors.map((item) => `$\{item.model\} @ $\{item.apiBase\}: $\{item.reason\}`).join(" | ")\line
    : lastError?.message || "Gemini request failed";\line
