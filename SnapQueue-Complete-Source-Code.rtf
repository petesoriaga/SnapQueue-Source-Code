  const hasSteps = /\\n\\d+\\.\\s/.test(nextAnswer);\line
  const hasLinks = /https?:\\/\\//i.test(nextAnswer);\line
  const hasHelpfulLinksLabel = /\\bHelpful links:\\b/i.test(nextAnswer);\line
  const isGreetingOnly = /^(hi|hello|hey|good (morning|afternoon|evening))( there)?[!. ]*$/i.test(String(question || "").trim());\line
\line
  nextAnswer = nextAnswer\line
    .split("\\n")\line
    .map((line) => normalizeHelpfulLinkLine(line))\line
    .join("\\n")\line
    .replace(/Hello there!\\s*Welcome to SnapQueue\\.[\\s\\S]*?How can I assist you today\\?/i, "Hi! I'm here to help with bookings, payments, account steps, and delivery updates.");\line
\line
  nextAnswer = nextAnswer\line
    .split("\\n")\line
    .map((line) => cleanAnswerArtifacts(line))\line
    .join("\\n");\line
\line
  nextAnswer = removeNonLinkHelpfulLinks(nextAnswer);\line
\line
  if (isGreetingOnly) \{\line
    nextAnswer = "Hi! I'm here to help with bookings, payments, account steps, and delivery updates.";\line
  \}\line
\line
  const splitBeforeConcise = splitHelpfulLinksBlock(nextAnswer);\line
  const conciseLines = splitBeforeConcise.body\line
    .split("\\n")\line
    .map((line) => line.trim())\line
    .filter(Boolean);\line
\line
  if (!wantsSteps && conciseLines.length > 4) \{\line
