    return res.status(400).json(\{ success: false, message: "Invalid payment status" \});\line
  \}\line
\line
  const payment = await Payment.findById(req.params.id);\line
  if (!payment) \{\line
    return res.status(404).json(\{ success: false, message: "Payment not found" \});\line
  \}\line
  const reservation = await Reservation.findById(payment.reservationId);\line
\line
  payment.status = status;\line
  if (status === "verified") \{\line
    payment.autoReviewStatus = payment.autoReviewFindings?.length ? "needs_review" : "clear";\line
    payment.paidAt = new Date();\line
    payment.failedAt = null;\line
    payment.failureReason = "";\line
    await payment.save();\line
    await applyStatusToReservation(payment.reservationId, "paid");\line
    if (reservation) \{\line
      await Reservation.updateOne(\line
        \{ _id: reservation._id \},\line
        \{\line
          $set: \{\line
            status: "approved",\line
            workflowStage: "awaiting_approval",\line
