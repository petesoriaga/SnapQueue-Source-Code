      return;\line
    \}\line
    const files = selectedPhotos\line
      .map((key) => \{\line
        const index = Number(String(key).split("::")[1]);\line
        const photo = currentPhotos[index];\line
        if (!photo?.url) return null;\line
        return \{\line
          publicId: photo.publicId || "",\line
          url: photo.url\line
        \};\line
      \})\line
      .filter(Boolean);\line
\line
    if (!files.length) \{\line
      setDeleteArchiveModalOpen(false);\line
      ignoreFeedback(\{ variant: "error", message: "Selected media could not be resolved." \});\line
      return;\line
    \}\line
\line
    try \{\line
      setDeleteArchivePending(true);\line
      try \{\line
        await api.post("/archive/me/files/delete", \{\line
          folderName: currentFolder.name,\line
          files\line
        \});\line
      \} catch (error) \{\line
        if (error?.response?.status !== 404) throw error;\line
        try \{\line
          await api.post("/archive/me/files", \{\line
            folderName: currentFolder.name,\line
            files\line
          \});\line
        \} catch (nestedError) \{\line
          if (nestedError?.response?.status !== 404) throw nestedError;\line
          try \{\line
            await api.post("/archive/me", \{\line
              folderName: currentFolder.name,\line
              files\line
            \});\line
