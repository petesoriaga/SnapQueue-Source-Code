      return;\line
    \}\line
    const isRefundReceipt = ["approved", "processed"].includes(refundStatus) || paymentStatus === "refunded";\line
    const receiptHtml = isRefundReceipt\line
      ? buildRefundDetailsHtml(reservation, resolvedPayment)\line
      : buildReceiptHtml(reservation, resolvedPayment);\line
