\line
function readBootstrapDelay(value, fallback) \{\line
  const parsed = Number.parseInt(String(value || "").trim(), 10);\line
  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\line
\}\line
\line
const MIN_BOOTSTRAP_MS = readBootstrapDelay(import.meta.env.VITE_BOOTSTRAP_MIN_MS, 800);\line
const MAX_BOOTSTRAP_MS = readBootstrapDelay(import.meta.env.VITE_BOOTSTRAP_MAX_MS, 8000);\line
\line
function delay(ms) \{\line
  return new Promise((resolve) => \{\line
    window.setTimeout(resolve, ms);\line
  \});\line
\}\line
\line
function BootstrapApp() \{\line
  const [ready, setReady] = useState(false);\line
\line
  useEffect(() => \{\line
    let active = true;\line
\line
    Promise.all([\line
      Promise.race([wakeBackend(), delay(MAX_BOOTSTRAP_MS)]),\line
      delay(MIN_BOOTSTRAP_MS)\line
    ]).finally(() => \{\line
      if (active) setReady(true);\line
    \});\line
\line
    return () => \{\line
      active = false;\line
    \};\line
  \}, []);\line
\line
  if (!ready) return <PageLoadingScreen />;\line
\line
  return <App />;\line
\}\line
\line
function GlobalBackgroundSync() \{\line
  useEffect(() => \{\line
    const rootElement = document.getElementById("root");\line
    const htmlElement = document.documentElement;\line
\line
    const syncBackground = () => \{\line
      const computed = window.getComputedStyle(document.body);\line
      const backgroundColor = computed.backgroundColor || "#020617";\line
      const backgroundImage = computed.backgroundImage || "none";\line
\line
      htmlElement.style.backgroundColor = backgroundColor;\line
      htmlElement.style.backgroundImage = backgroundImage;\line
      document.body.style.backgroundColor = backgroundColor;\line
\line
      if (rootElement) \{\line
        rootElement.style.backgroundColor = backgroundColor;\line
        rootElement.style.backgroundImage = backgroundImage;\line
        rootElement.style.minHeight = "100%";\line
      \}\line
    \};\line
\line
    syncBackground();\line
\line
    const observer = new MutationObserver(() => \{\line
      syncBackground();\line
    \});\line
\line
    observer.observe(document.body, \{\line
      attributes: true,\line
      attributeFilter: ["class", "style"]\line
    \});\line
\line
    window.addEventListener("resize", syncBackground);\line
    window.addEventListener("pageshow", syncBackground);\line
\line
    return () => \{\line
      observer.disconnect();\line
      window.removeEventListener("resize", syncBackground);\line
      window.removeEventListener("pageshow", syncBackground);\line
    \};\line
  \}, []);\line
\line
  return null;\line
\}\line
\line
ReactDOM.createRoot(document.getElementById("root")).render(\line
  <React.StrictMode>\line
    <BrowserRouter>\line
      <GlobalBackgroundSync />\line
      <BootstrapApp />\line
    </BrowserRouter>\line
  </React.StrictMode>\line
);\line
