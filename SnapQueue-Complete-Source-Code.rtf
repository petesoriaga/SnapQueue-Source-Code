const RESERVATION_CODE_PREFIX = "SQ-";\line
const RESERVATION_CODE_BODY_LENGTH = 9;\line
const RESERVATION_CODE_ALPHABET = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";\line
\line
export function generateReservationCode() \{\line
  let body = "";\line
  for (let index = 0; index < RESERVATION_CODE_BODY_LENGTH; index += 1) \{\line
    const position = Math.floor(Math.random() * RESERVATION_CODE_ALPHABET.length);\line
    body += RESERVATION_CODE_ALPHABET[position];\line
  \}\line
  return `$\{RESERVATION_CODE_PREFIX\}$\{body\}`;\line
\}\line
\line
export function getDisplayReservationId(reservationLike) \{\line
  return String(reservationLike?.reservationCode || reservationLike?._id || reservationLike?.id || "").trim() || "-";\line
\}\line
