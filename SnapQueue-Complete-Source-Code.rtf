        const index = Number(String(key).split("::")[1]);\line
        const photo = currentPhotos[index];\line
        if (!photo?.url) continue;\line
        const preferredName = buildPreferredDownloadName(currentFolder?.name, photo, settingsPreferences.downloadFormat, order);\line
        const response = await fetch(buildDownloadUrl(photo.url, settingsPreferences.downloadQuality, photo));\line
        if (!response.ok) \{\line
          throw new Error(`Failed to download $\{preferredName\}.`);\line
        \}\line
        const blob = await response.blob();\line
        selectedMedia.push(\{ blob, preferredName, photo \});\line
      \}\line
\line
      if (settingsPreferences.downloadFormat === "zip" || settingsPreferences.downloadFormat === "folder") \{\line
        const zip = new JSZip();\line
        const safeFolderName = getSafeArchiveFolderName(currentFolder?.name);\line
        const zipFolder = settingsPreferences.downloadFormat === "folder" ? zip.folder(safeFolderName) : null;\line
        selectedMedia.forEach((\{ blob, preferredName \}) => \{\line
          if (zipFolder) \{\line
            zipFolder.file(preferredName, blob);\line
            return;\line
          \}\line
          zip.file(preferredName, blob);\line
        \});\line
        const zipBlob = await zip.generateAsync(\{ type: "blob" \});\line
        const zipUrl = window.URL.createObjectURL(zipBlob);\line
        const anchor = document.createElement("a");\line
        anchor.href = zipUrl;\line
        anchor.download = settingsPreferences.downloadFormat === "folder"\line
          ? `$\{safeFolderName\}.zip`\line
          : buildArchiveZipName(currentFolder?.name);\line
        document.body.appendChild(anchor);\line
        anchor.click();\line
        anchor.remove();\line
        window.URL.revokeObjectURL(zipUrl);\line
      \} else \{\line
        selectedMedia.forEach((\{ blob, preferredName \}) => \{\line
          const objectUrl = window.URL.createObjectURL(blob);\line
          const anchor = document.createElement("a");\line
          anchor.href = objectUrl;\line
          anchor.download = preferredName;\line
          document.body.appendChild(anchor);\line
          anchor.click();\line
          anchor.remove();\line
          window.URL.revokeObjectURL(objectUrl);\line
        \});\line
      \}\line
    \} catch (error) \{\line
      ignoreFeedback(\{ variant: "error", message: error?.message || "Failed to download selected media." \});\line
      return;\line
    \}\line
