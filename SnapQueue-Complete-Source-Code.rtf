export const askAI = async (req, res) => \{\line
  const question = String(req.body?.question || "").trim();\line
  if (!question) \{\line
    return res.status(400).json(\{ success: false, message: "Question is required" \});\line
  \}\line
  if (question.length > MAX_AI_INPUT_LENGTH) \{\line
    return res.status(400).json(\{\line
      success: false,\line
      message: `Question must be $\{MAX_AI_INPUT_LENGTH\} characters or less`\line
