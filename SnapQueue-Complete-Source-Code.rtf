export function getDisplayName(thread) \{\line
  return thread?.clientName || thread?.clientEmail || "Client";\line
\}\line
\line
export function getProfileHandle(profile, thread) \{\line
  const explicit = String(profile?.username || "").trim();\line
  if (explicit) return explicit.replace(/^@/, "");\line
\line
  const email = String(profile?.email || thread?.clientEmail || "").trim().toLowerCase();\line
  if (email.includes("@")) return email.split("@")[0];\line
