import mongoose from "mongoose";\line
import dns from "node:dns";\line
\line
export const connectDB = async () => \{\line
  let mongoUri = String(process.env.MONGO_URI || "");\line
  // Normalize common formatting mistakes from env providers.\line
  mongoUri = mongoUri.replace(/^\\uFEFF/, "").trim();\line
  if (/^MONGO_URI\\s*=/.test(mongoUri)) \{\line
    mongoUri = mongoUri.replace(/^MONGO_URI\\s*=\\s*/i, "");\line
  \}\line
  if (\line
    (mongoUri.startsWith('"') && mongoUri.endsWith('"')) ||\line
    (mongoUri.startsWith("'") && mongoUri.endsWith("'"))\line
  ) \{\line
    mongoUri = mongoUri.slice(1, -1).trim();\line
  \}\line
  if (!mongoUri) \{\line
    throw new Error("MONGO_URI is not set");\line
  \}\line
  if (!mongoUri.startsWith("mongodb://") && !mongoUri.startsWith("mongodb+srv://")) \{\line
    throw new Error('MONGO_URI must start with "mongodb://" or "mongodb+srv://"');\line
  \}\line
  if (mongoUri.includes("159.143.174.145")) \{\line
    throw new Error("Blocked legacy Mongo host 159.143.174.145 detected in MONGO_URI.");\line
  \}\line
  const dbNameMatch = mongoUri.match(/\\/([^/?]+)(\\?|$)/);\line
  const dbName = (dbNameMatch ? dbNameMatch[1] : "").trim().toLowerCase();\line
  if (dbName === "test") \{\line
    throw new Error("Blocked database name 'test'. Please use the SnapQueue database.");\line
  \}\line
\line
  const maskedMongoUri = mongoUri\line
    .replace(/\\/\\/[^@]+@/, "//<redacted>@")\line
    .replace(/\\?.*$/, "");\line
  console.log(`[env] MONGO_URI detected: $\{maskedMongoUri\}`);\line
\line
  // Ensure SRV lookups work even when the OS resolver is flaky.\line
  try \{\line
    dns.setServers(["1.1.1.1", "8.8.8.8"]);\line
  \} catch (_error) \{\line
    // ignore dns override failures\line
  \}\line
\line
  mongoose.set("bufferCommands", false);\line
  await mongoose.connect(mongoUri, \{\line
    serverSelectionTimeoutMS: 10000,\line
    connectTimeoutMS: 10000,\line
    socketTimeoutMS: 45000\line
  \});\line
  console.log("MongoDB connected");\line
\};\line
