    return date.toLocaleTimeString("en-US", \{\line
      hour: "numeric",\line
      minute: "2-digit"\line
    \});\line
  \}\line
  return date.toLocaleDateString("en-US", \{\line
    month: "short",\line
    day: "numeric"\line
