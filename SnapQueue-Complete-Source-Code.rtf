    err.code = 404;\line
    throw err;\line
  \}\line
  if (!hasAdminAccess(user?.role) && !isReservationOwner(reservation, user)) \{\line
    const err = new Error("Forbidden");\line
    err.code = 403;\line
    throw err;\line
  \}\line
