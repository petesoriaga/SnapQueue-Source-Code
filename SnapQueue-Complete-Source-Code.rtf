          : "New password and confirmation are required."\line
      \});\line
      return;\line
    \}\line
    if (requiresCurrentPassword) \{\line
      try \{\line
        await api.post("/users/me/password/verify-current", \{ currentPassword: passwordForm.currentPassword \}, \{ timeout: 30000 \});\line
      \} catch (error) \{\line
        const message = error?.response?.data?.message || "Current password is incorrect.";\line
        setPasswordErrors((current) => (\{ ...current, currentPassword: message \}));\line
