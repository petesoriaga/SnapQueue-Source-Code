    if (name === "street") return trimmed ? "" : "Please complete the street field";\line
    if (name === "eventTypeOtherDetails") return nextForm.eventType !== "other" || trimmed ? "" : "Please specify the other event type";\line
    if (name === "eventDateTime") return isReservationDateValid(value) ? "" : EVENT_DATE_VALIDATION_MESSAGE;\line
