\};\line
\line
export const createAd = async (req, res) => \{\line
  const payload = normalizePayload(req.body);\line
  if (!payload.title) \{\line
    return res.status(400).json(\{ success: false, message: "Title is required" \});\line
  \}\line
  const dateRangeError = assertDateRange(payload.startDate, payload.endDate);\line
  if (dateRangeError) \{\line
    return res.status(400).json(\{ success: false, message: dateRangeError \});\line
  \}\line
  const scheduleAvailabilityError = await assertScheduleAvailability(toDayStart(payload.startDate), toDayEnd(payload.endDate));\line
  if (scheduleAvailabilityError) \{\line
    return res.status(400).json(\{ success: false, message: scheduleAvailabilityError \});\line
  \}\line
\line
  const ad = await Advertisement.create(\{\line
    ...payload,\line
    startDate: toDayStart(payload.startDate),\line
    endDate: toDayEnd(payload.endDate),\line
    createdBy: req.user?.sub || null,\line
    updatedBy: req.user?.sub || null\line
  \});\line
\line
  res.status(201).json(\{ success: true, ad \});\line
\};\line
\line
export const updateAd = async (req, res) => \{\line
  const adId = String(req.params.id || "");\line
  if (!mongoose.Types.ObjectId.isValid(adId)) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid ad id" \});\line
  \}\line
\line
  const current = await Advertisement.findById(adId);\line
  if (!current) \{\line
    return res.status(404).json(\{ success: false, message: "Ad not found" \});\line
  \}\line
\line
  const payload = normalizePayload(req.body);\line
  const startDate = Object.prototype.hasOwnProperty.call(payload, "startDate")\line
    ? toDayStart(payload.startDate)\line
    : current.startDate;\line
  const endDate = Object.prototype.hasOwnProperty.call(payload, "endDate")\line
    ? toDayEnd(payload.endDate)\line
    : current.endDate;\line
  const dateRangeError = assertDateRange(startDate, endDate);\line
  if (dateRangeError) \{\line
    return res.status(400).json(\{ success: false, message: dateRangeError \});\line
  \}\line
  const scheduleAvailabilityError = await assertScheduleAvailability(startDate, endDate, adId);\line
  if (scheduleAvailabilityError) \{\line
    return res.status(400).json(\{ success: false, message: scheduleAvailabilityError \});\line
  \}\line
\line
  const ad = await Advertisement.findByIdAndUpdate(\line
    adId,\line
    \{\line
      $set: \{\line
        ...payload,\line
        ...(Object.prototype.hasOwnProperty.call(payload, "startDate") ? \{ startDate \} : \{\}),\line
        ...(Object.prototype.hasOwnProperty.call(payload, "endDate") ? \{ endDate \} : \{\}),\line
        updatedBy: req.user?.sub || null\line
      \}\line
    \},\line
    \{ new: true \}\line
  );\line
  res.json(\{ success: true, ad \});\line
\};\line
\line
export const deleteAd = async (req, res) => \{\line
  const adId = String(req.params.id || "");\line
  if (!mongoose.Types.ObjectId.isValid(adId)) \{\line
    return res.status(400).json(\{ success: false, message: "Invalid ad id" \});\line
  \}\line
\line
  const deleted = await Advertisement.findByIdAndDelete(adId);\line
  if (!deleted) \{\line
    return res.status(404).json(\{ success: false, message: "Ad not found" \});\line
  \}\line
\line
  res.json(\{ success: true, message: "Advertisement deleted" \});\line
\};\line
