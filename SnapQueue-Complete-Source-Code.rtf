  async function refreshPaymentState(reservationId = activePaymentReservationId) \{\line
    if (!reservationId) return;\line
    try \{\line
      const response = await api.get(`/payments/reservation/$\{reservationId\}`);\line
      const nextPayment = response?.data?.payment || null;\line
      setActivePayment(nextPayment);\line
      setPaymentsByReservationId((current) => (\{\line
        ...current,\line
        [String(reservationId)]: nextPayment\line
      \}));\line
    \} catch (_error) \{\line
      const currentPayment = paymentsByReservationIdRef.current[String(reservationId)] || null;\line
      if (String(activePaymentReservationId) === String(reservationId)) \{\line
        setActivePayment(currentPayment);\line
      \}\line
    \}\line
  \}\line
