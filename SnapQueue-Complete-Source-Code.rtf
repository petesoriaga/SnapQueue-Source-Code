import \{ useEffect, useState \} from "react";\line
import \{ Navigate, Route, Routes, useLocation, useNavigate \} from "react-router-dom";\line
import GalleryPage from "./features/public/pages/GalleryPage";\line
import ContactFaqPage from "./features/public/pages/ContactFaqPage";\line
import AdminDashboardPage from "./features/admin/pages/AdminDashboardPage";\line
import AdminHelpCenterPage from "./features/admin/pages/AdminHelpCenterPage";\line
import DashboardPage from "./features/user/pages/DashboardPage";\line
import HelpCenterPage from "./features/user/pages/HelpCenterPage";\line
import IndexPage from "./features/public/pages/IndexPage";\line
import LoginPage from "./features/public/pages/LoginPage";\line
import MaintenancePage from "./features/public/pages/MaintenancePage";\line
import Payment from "./features/user/pages/Payment";\line
import ReservationPage from "./features/user/pages/ReservationPage";\line
import NotFoundPage from "./features/public/pages/NotFoundPage";\line
import TermsPage from "./features/public/pages/TermsPage";\line
import PrivacyPolicyPage from "./features/public/pages/PrivacyPolicyPage";\line
import DataDeletionPage from "./features/public/pages/DataDeletionPage";\line
import api from "./shared/services/api";\line
\line
const TERMS_RETURN_KEY = "snapqueue_terms_return";\line
const MAINTENANCE_EXEMPT_PATHS = new Set(["/maintenance", "/admin"]);\line
\line
function hasAdminAccess(role) \{\line
  const normalized = String(role || "")\line
    .trim()\line
    .toLowerCase()\line
    .replace(/[\\s-]+/g, "_");\line
  return normalized === "admin" || normalized === "super_admin" || normalized === "superadmin";\line
\}\line
\line
function ScrollToTop() \{\line
  const \{ pathname, search \} = useLocation();\line
\line
  useEffect(() => \{\line
    if (pathname === "/reservation") \{\line
      const raw = window.sessionStorage.getItem(TERMS_RETURN_KEY);\line
      if (raw) \{\line
        try \{\line
          const parsed = JSON.parse(raw);\line
          if (parsed?.returnTo === `$\{pathname\}$\{search\}` && typeof parsed?.returnScrollY === "number") \{\line
            return;\line
          \}\line
        \} catch \{\line
          window.sessionStorage.removeItem(TERMS_RETURN_KEY);\line
        \}\line
      \}\line
    \}\line
    window.scrollTo(\{ top: 0, left: 0, behavior: "auto" \});\line
  \}, [pathname, search]);\line
\line
  return null;\line
\}\line
\line
function WebsiteAvailabilityGate() \{\line
  const \{ pathname \} = useLocation();\line
  const navigate = useNavigate();\line
  const [lastMode, setLastMode] = useState("");\line
\line
  useEffect(() => \{\line
    let cancelled = false;\line
\line
    const enforceAvailability = async () => \{\line
      try \{\line
        const response = await api.get("/system/status");\line
        const activeMode = String(response?.data?.system?.activeMode || "").trim().toLowerCase();\line
        if (!activeMode) \{\line
          if (!cancelled) \{\line
            setLastMode("");\line
            if (pathname === "/maintenance") \{\line
              navigate("/", \{ replace: true \});\line
            \}\line
          \}\line
          return;\line
        \}\line
\line
        if (pathname === "/maintenance") \{\line
          if (!cancelled) \{\line
            setLastMode(activeMode);\line
          \}\line
          return;\line
        \}\line
\line
        if (MAINTENANCE_EXEMPT_PATHS.has(pathname)) return;\line
\line
        const token = window.localStorage.getItem("token");\line
        let isAdmin = false;\line
        if (token) \{\line
          try \{\line
            const me = await api.get("/auth/me");\line
            isAdmin = hasAdminAccess(me?.data?.user?.role);\line
          \} catch (_error) \{\line
            isAdmin = false;\line
          \}\line
        \}\line
\line
        if (!cancelled) \{\line
          setLastMode(activeMode);\line
          if (!isAdmin) \{\line
            navigate(`/maintenance?mode=$\{encodeURIComponent(activeMode)\}`, \{ replace: true \});\line
          \}\line
        \}\line
      \} catch (_error) \{\line
        if (!cancelled) setLastMode("");\line
      \}\line
    \};\line
\line
    enforceAvailability();\line
    return () => \{\line
      cancelled = true;\line
    \};\line
  \}, [navigate, pathname]);\line
\line
  useEffect(() => \{\line
    if (pathname !== "/maintenance" || !lastMode) return;\line
    const params = new URLSearchParams(window.location.search);\line
    if (params.get("mode") === lastMode) return;\line
    navigate(`/maintenance?mode=$\{encodeURIComponent(lastMode)\}`, \{ replace: true \});\line
  \}, [lastMode, navigate, pathname]);\line
\line
  return null;\line
\}\line
\line
export default function App() \{\line
  return (\line
    <>\line
      <ScrollToTop />\line
      <WebsiteAvailabilityGate />\line
      <Routes>\line
        <Route path="/" element=\{<IndexPage />\} />\line
        <Route path="/gallery" element=\{<GalleryPage />\} />\line
        <Route path="/contact" element=\{<ContactFaqPage />\} />\line
        <Route path="/login" element=\{<LoginPage />\} />\line
        <Route path="/dashboard" element=\{<DashboardPage />\} />\line
        <Route path="/dashboard-native-preview" element=\{<DashboardPage />\} />\line
        <Route path="/help-center" element=\{<HelpCenterPage />\} />\line
        <Route path="/admin-help-center" element=\{<AdminHelpCenterPage />\} />\line
        <Route path="/admin" element=\{<AdminDashboardPage />\} />\line
        <Route path="/reservation" element=\{<ReservationPage />\} />\line
        <Route path="/payment" element=\{<Payment />\} />\line
        <Route path="/terms" element=\{<TermsPage />\} />\line
        <Route path="/privacy-policy" element=\{<PrivacyPolicyPage />\} />\line
        <Route path="/data-deletion" element=\{<DataDeletionPage />\} />\line
        <Route path="/maintenance" element=\{<MaintenancePage />\} />\line
        <Route path="/home" element=\{<Navigate to="/" replace />\} />\line
        <Route path="*" element=\{<NotFoundPage />\} />\line
      </Routes>\line
    </>\line
  );\line
\}\line
\line
