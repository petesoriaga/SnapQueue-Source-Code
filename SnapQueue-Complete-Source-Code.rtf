\line
export default function MaintenancePage() \{\line
  const location = useLocation();\line
  const bodyClassRef = useRef(document.body.className);\line
  const queryMode = useMemo(() => String(new URLSearchParams(location.search).get("mode") || "").trim().toLowerCase(), [location.search]);\line
  const [mode, setMode] = useState(queryMode || "default");\line
  const [message, setMessage] = useState(MODE_COPY[queryMode] || MODE_COPY.default);\line
\line
  useEffect(() => \{\line
    document.title = "SnapQueue";\line
    document.body.className = "m-0 min-h-screen bg-slate-950 text-white";\line
    return () => \{\line
      document.body.className = bodyClassRef.current;\line
    \};\line
  \}, []);\line
\line
  useEffect(() => \{\line
    const initialMode = MODE_COPY[queryMode] ? queryMode : "default";\line
    setMode(initialMode);\line
    setMessage(MODE_COPY[initialMode] || MODE_COPY.default);\line
  \}, [queryMode]);\line
\line
  useEffect(() => \{\line
    const loadStatus = async () => \{\line
      try \{\line
        const response = await api.get("/system/status");\line
        const system = response?.data?.system || \{\};\line
        const activeMode = String(system.activeMode || "").trim().toLowerCase();\line
        if (MODE_COPY[activeMode]) \{\line
          setMode(activeMode);\line
          setMessage(\{\line
